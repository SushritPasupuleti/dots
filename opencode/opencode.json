{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/grok-code-fast-1",
  "autoupdate": true,
    "permission": {
	"read": "allow",
    "edit": "ask",
	"patch": "allow",
	"grep": "allow",
	"glob": "allow",
	"list": "allow",
	"lsp": "allow",
	"skill": "allow",
	"todowrite": "allow",
	"todoread": "allow",
    "bash": "ask",
	"webfetch": "allow",
	"question": "allow"
  },
    "compaction": {
    "auto": true,
    "prune": true
  },
    "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "instructions": ["CONTRIBUTING.md", "docs/guidelines.md", ".cursor/rules/*.md"]
}
